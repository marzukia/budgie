{
  "name": "budgie-frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "biome check --apply src/",
    "format": "biome format --write src/",
    "check": "biome check src/",
    "test": "echo 'No frontend tests yet' && exit 0",
    "prepare": "husky",
    "preview": "vite preview",
    "codegen": "openapi-typescript http://localhost:8000/api/openapi.json --output src/api/generated.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "lint-staged": {
    "*.ts": "biome check --apply",
    "*.tsx": "biome check --apply"
  },
  "dependencies": {
    "@mantine/core": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@mantine/notifications": "^9.3.2",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5",
    "@tanstack/react-router": "^1",
    "openapi-fetch": "^0.12",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "^2",
    "zustand": "^5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@playwright/test": "^1",
    "@tanstack/router-generator": "^1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "husky": "^9",
    "jsdom": "^29.1.1",
    "lint-staged": "^16",
    "openapi-typescript": "^7",
    "typescript": "^5.6",
    "vite": "^6",
    "vitest": "^4.1.9"
  }
}
