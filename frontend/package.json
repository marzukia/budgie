{
  "name": "budgie-frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "biome check --apply src/",
    "format": "biome format --write src/",
    "check": "biome check src/",
    "prepare": "husky",
    "preview": "vite preview",
    "codegen": "openapi-typescript http://localhost:8000/api/openapi.json --output src/api/generated.ts"
  },
  "lint-staged": {
    "*.ts": "biome check --apply",
    "*.tsx": "biome check --apply"
  },
  "dependencies": {
    "@tanstack/react-query": "^5",
    "@tanstack/react-router": "^1",
    "openapi-fetch": "^0.12",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "^2",
    "zustand": "^5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@playwright/test": "^1",
    "@tanstack/router-generator": "^1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "husky": "^9",
    "lint-staged": "^16",
    "openapi-typescript": "^7",
    "typescript": "^5.6",
    "vite": "^6"
  }
}
